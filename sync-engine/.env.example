# Same project as the Next.js site (Project Settings → API).
SUPABASE_URL=https://your-project.supabase.co

# Service role key (keep secret; never expose in the browser). Required to write under RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Your Supabase auth user id — copy from the web app: Dashboard → Settings → Local sync.
# Must match the first segment of keys in the project-files Storage bucket (see website/supabase-storage.sql).
SYNC_USER_ID=00000000-0000-0000-0000-000000000000

# Optional: same URL/key names as the website .env
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
