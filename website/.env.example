# Supabase — Project Settings → API (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Postgres for Prisma (Supabase → Project Settings → Database → Connection string)
# Paste the URI from the dashboard (Transaction pooler :6543 or direct :5432). Replace placeholders only—
# do not leave square brackets. If the password contains @ : / ? # or spaces, URL-encode it (e.g. @ → %40, ? → %3F).
# Node: encodeURIComponent("your-db-password") and paste only that as the password segment.
# Save the file as UTF-8; avoid stray characters after the URL (Windows CRLF at EOL is OK).
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Same password; use Session/Direct URI (often db.*.supabase.co:5432 or pooler :5432) for prisma db push / migrate.
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Local folder sync: run ../sync-engine with SUPABASE_SERVICE_ROLE_KEY + SYNC_USER_ID (see sync-engine/.env.example).
# After schema: run supabase-schema.sql then supabase-storage.sql (Storage buckets: project-files, avatars).

# Google OAuth: Supabase → Authentication → Providers → Google (enable + add Client ID/Secret).
# Authentication → URL Configuration → add redirect: http://localhost:3000/auth/callback (and production URL).
